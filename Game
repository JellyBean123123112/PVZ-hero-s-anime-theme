function wait(ms){return new Promise(r=>setTimeout(r,ms))}

/* ══════════════════════════════
   EVOLUTION SYSTEM
══════════════════════════════ */
function tickEvolutions(){
  let evolved=false;
  for(let i=0;i<5;i++){
    const card=G.pRow[i];
    if(!card||!card.evolve)continue;
    const ev=card.evolve;

    if(ev.repeating){
      // Rock Lee style: buff every N turns
      card.turnsOnBoard=(card.turnsOnBoard||0)+1;
      if(card.turnsOnBoard%ev.turnsNeeded===0){
        if(ev.buffPerTurn.atk)card.atk+=ev.buffPerTurn.atk;
        if(ev.buffPerTurn.hp){card.hp+=ev.buffPerTurn.hp;card.curHP=(card.curHP||card.hp)+ev.buffPerTurn.hp;}
        flashTrick(`🥋 ${card.name} grows stronger!`,'var(--ac)');
        evolved=true;
      }
    } else {
      // One-time evolution (Gon)
      card.turnsOnBoard=(card.turnsOnBoard||0)+1;
      if(card.turnsOnBoard>=ev.turnsNeeded){
        const base=CARDS.find(c=>c.id===ev.intoId);
        if(base){
          const evolved_card=mkCard(base);
          evolved_card.uid=card.uid; // keep same uid so lane stays
          G.pRow[i]=evolved_card;
          flashTrick(`⚡ ${card.name} EVOLVED!`,'var(--ac)');
          showBanner(`⚡ EVOLVED!`,`${base.name} is here`,'var(--ac)');
          evolved=true;
        }
      }
    }
  }
  if(evolved)renderGame();
}

/* ══════════════════════════════
   COMBAT
══════════════════════════════ */
async function runCombat(){
  const cp=document.querySelectorAll('#prow .lcell');
  const cz=document.querySelectorAll('#zrow .lcell');

  for(let i=0;i<5;i++){
    const p=G.pRow[i],z=G.zRow[i];
    if(!p&&!z)continue;

    if(p&&z){
      const pe=cp[i]?.querySelector('.card'),ze=cz[i]?.querySelector('.card');
      if(pe)pe.classList.add('a-atkp');
      if(ze)ze.classList.add('a-atkz');
      await wait(190);

      const frozen=G.frozenZones.includes(i);
      if(!frozen){p.curHP=(p.curHP||p.hp)-z.atk;}
      z.curHP=(z.curHP||z.hp)-p.atk;
      G.totalDmgDealt+=p.atk;

      if(pe){pe.classList.remove('a-atkp');showDmg(cp[i],z.atk,'var(--rd)');pe.classList.add('a-shake')}
      if(ze&&!frozen){ze.classList.remove('a-atkz');showDmg(cz[i],p.atk,'var(--ac)');ze.classList.add('a-shake')}
      await wait(280);

      if((p.curHP||p.hp)<=0){if(pe)pe.classList.add('a-die');await wait(330);G.pRow[i]=null;}
      if((z.curHP||z.hp)<=0){
        if(ze)ze.classList.add('a-die');
        await wait(330);G.zRow[i]=null;
        gainSuperCharge(1); // kill = charge
      }

    } else if(z&&!G.frozenZones.includes(i)){
      const ze=cz[i]?.querySelector('.card');
      if(ze)ze.classList.add('a-atkz');
      await wait(230);
      if(!G.gojoShield){
        G.pHP=Math.max(0,G.pHP-z.atk);
        showDmg(document.getElementById('gtop'),z.atk,'var(--rd)',true);
        document.getElementById('gpp').classList.add('a-shake');
      } else {
        flashTrick('🌀 BLOCKED by Infinity!','var(--bl)');
      }
      await wait(380);
      if(ze)ze.classList.remove('a-atkz');

    } else if(p){
      const pe=cp[i]?.querySelector('.card');
      if(pe)pe.classList.add('a-atkp');
      await wait(230);
      const dmg=p.atk;
      G.zHP=Math.max(0,G.zHP-dmg);
      G.totalDmgDealt+=dmg;
      showDmg(document.getElementById('gtop'),dmg,'var(--ac)',false);
      document.getElementById('gzp').classList.add('a-shake');
      gainSuperCharge(1); // uncontested hit = charge
      await wait(380);
      if(pe)pe.classList.remove('a-atkp');
    }
    renderGame();await wait(150);
  }
}

function showDmg(parent,dmg,color,left=true){
  const el=document.createElement('div');
  el.className='dmgf';el.textContent='-'+dmg;el.style.color=color;
  el.style[left?'left':'right']='16px';el.style.top='6px';
  parent.style.position='relative';parent.appendChild(el);
  setTimeout(()=>el.remove(),850);
}

/* ══════════════════════════════
   SMART AI TURN
══════════════════════════════ */
async function aiTurn(){
  const zcs=CARDS.filter(c=>c.type==='zombie');
  const ztricks=CARDS.filter(c=>c.type==='trick-zombie');
  let placed=0;

  // --- TRICK LOGIC: use tricks strategically ---
  // If plant hero is low, try dmgHero trick
  if(G.pHP<=15&&G.brains>=2){
    const heroKill=ztricks.find(t=>t.effect&&t.effect.dmgHero&&t.cost<=G.brains);
    if(heroKill){
      G.brains-=heroKill.cost;
      applyTrickEffect(heroKill.effect,heroKill,-1,'zombie');
      renderGame();await wait(500);
    }
  }
  // If plants filling up, use destroyWeakest
  const plantCount=G.pRow.filter(Boolean).length;
  if(plantCount>=3&&G.brains>=1){
    const destroy=ztricks.find(t=>t.effect&&t.effect.destroyWeakest&&t.cost<=G.brains);
    if(destroy){
      G.brains-=destroy.cost;
      applyTrickEffect(destroy.effect,destroy,-1,'zombie');
      renderGame();await wait(500);
    }
  }
  // Occasionally use Raiding Party / Blood Demon Art / Meteor Shower
  if(G.brains>=3&&Math.random()<0.3){
    const misc=ztricks.filter(t=>t.effect&&(t.effect.spawnZombies||t.effect.extraBrains||t.effect.dmgAllPlants)&&t.cost<=G.brains);
    if(misc.length){
      const t=misc[Math.floor(Math.random()*misc.length)];
      G.brains-=t.cost;
      applyTrickEffect(t.effect,t,-1,'zombie');
      renderGame();await wait(400);
    }
  }

  // --- UNIT PLACEMENT: prioritize threat lanes ---
  // Build priority lane list: block strong plants first, then open lanes
  const laneOrder=[];
  // Lanes with strong plants (atk >= 3): block them
  G.pRow.forEach((p,i)=>{
    if(p&&p.atk>=3&&!G.zRow[i])laneOrder.push(i);
  });
  // Lanes already contested that zombie is losing: reinforce
  G.pRow.forEach((p,i)=>{
    if(p&&G.zRow[i]&&(G.zRow[i].curHP||G.zRow[i].hp)<=p.atk&&!laneOrder.includes(i))laneOrder.push(i);
  });
  // Open lanes the player hasn't claimed
  for(let i=0;i<5;i++){
    if(!G.pRow[i]&&!G.zRow[i]&&!laneOrder.includes(i))laneOrder.push(i);
  }
  // Remaining lanes
  for(let i=0;i<5;i++){if(!laneOrder.includes(i)&&!G.zRow[i])laneOrder.push(i)}

  for(const lane of laneOrder){
    if(placed>=2||G.brains<=0)break;
    if(G.zRow[lane])continue; // already occupied

    // Choose card smartly: if blocking a high-atk plant, pick high-HP card
    const plantInLane=G.pRow[lane];
    let pool=zcs.filter(c=>c.cost<=G.brains);
    if(!pool.length)break;
    let chosen;
    if(plantInLane&&plantInLane.atk>=3){
      // pick highest HP affordable
      chosen=pool.reduce((a,b)=>b.hp>a.hp?b:a);
    } else {
      // pick highest attack affordable
      chosen=pool.reduce((a,b)=>b.atk>a.atk?b:a);
    }
    G.zRow[lane]=mkCard(chosen);
    G.brains-=chosen.cost;placed++;
    renderGame();await wait(400);
  }
}

