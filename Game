/* ══════════════════════════════
   DECK BUILDER
══════════════════════════════ */
const deck={};const MAX_C=2,MAX_D=20,MIN_D=10;
let dkFilter='all';
function dkTotal(){return Object.values(deck).reduce((a,b)=>a+b,0)}
function dkCnt(id){return deck[id]||0}

function setFilter(f,btn){
  dkFilter=f;
  document.querySelectorAll('.dfb').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  buildDeckPool();
}

function buildDeckPool(){
  const pool=document.getElementById('dpool');
  pool.innerHTML='';
  CARDS.filter(c=>{
    if(c.isEvolved)return false; // evolved forms not deckable
    if(dkFilter==='all')return true;
    if(dkFilter==='trick')return c.type.startsWith('trick');
    return c.type===dkFilter&&!c.type.startsWith('trick');
  }).forEach(card=>{
    const cnt=dkCnt(card.id);
    const maxed=cnt>=MAX_C;
    const wrap=document.createElement('div');
    wrap.className=`pi${maxed?' maxed':''}${cnt>0?' has':''}`;
    wrap.dataset.id=card.id;
    const ce=mkCardEl({...card,uid:'pool-'+card.id});
    ce.style.cursor='pointer';ce.style.width='100%';ce.style.height='auto';ce.style.aspectRatio='.72';
    const badge=document.createElement('div');
    badge.className='pbadge';badge.textContent=`${cnt}/${MAX_C}`;
    wrap.appendChild(ce);wrap.appendChild(badge);
    wrap.onclick=()=>{ if(!maxed)addToDeck(card.id); else notify('Max 2 copies','var(--rd)'); };
    let pt;
    wrap.addEventListener('pointerdown',()=>{pt=setTimeout(()=>showPoolInfo(card),400)});
    wrap.addEventListener('pointerup',()=>clearTimeout(pt));
    wrap.addEventListener('pointercancel',()=>clearTimeout(pt));
    pool.appendChild(wrap);
  });
}

function addToDeck(id){
  if(dkTotal()>=MAX_D){notify('Deck full','var(--rd)');return}
  if(dkCnt(id)>=MAX_C){notify('Max 2 copies','var(--rd)');return}
  deck[id]=(deck[id]||0)+1;
  const w=document.querySelector(`.pi[data-id="${id}"]`);
  if(w){const r=document.createElement('div');r.className='prpl';w.appendChild(r);setTimeout(()=>r.remove(),400)}
  syncDeck();
}

function rmFromDeck(id){
  if(!deck[id])return;
  deck[id]--;if(deck[id]<=0)delete deck[id];
  syncDeck();
}

function clearDeck(){Object.keys(deck).forEach(k=>delete deck[k]);syncDeck();notify('Deck cleared','var(--mu)')}

function syncDeck(){
  buildDeckPool();
  const list=document.getElementById('dklist');
  list.innerHTML='';
  Object.entries(deck).sort((a,b)=>{
    const ca=CARDS.find(c=>c.id===a[0]),cb=CARDS.find(c=>c.id===b[0]);
    return ca.cost-cb.cost;
  }).forEach(([id,cnt])=>{
    const card=CARDS.find(c=>c.id===id);if(!card)return;
    const row=document.createElement('div');
    row.className='dkrow';
    row.innerHTML=`<div class="dkart">${card.art}</div>
      <div class="dkname">${card.name}</div>
      <div class="dkcost">${card.cost}</div>
      <div class="dkctl">
        <button class="dkbtn m" onclick="rmFromDeck('${id}')">−</button>
        <div class="dkcnt">${cnt}</div>
        <button class="dkbtn p" ${cnt>=MAX_C?'disabled':''} onclick="addToDeck('${id}')">+</button>
      </div>`;
    list.appendChild(row);
  });
  const tot=dkTotal();
  document.getElementById('dtfil').style.width=(tot/MAX_D*100)+'%';
  document.getElementById('dtct').textContent=`${tot}/20`;
  const lbl=document.getElementById('dtlbl');
  const btn=document.getElementById('dtsave');
  if(tot<MIN_D){lbl.textContent=`Need ${MIN_D-tot} more`;lbl.className='dtlbl warn';btn.className='dtsave no';btn.textContent='Add more cards'}
  else{lbl.textContent=`${tot} cards · ready`;lbl.className='dtlbl ok';btn.className='dtsave ok';btn.textContent='Save Deck ✓'}
}

function saveDeck(){if(dkTotal()<MIN_D)return;notify('Deck saved ✓','var(--gr)');setTimeout(()=>goTab(0),600)}

