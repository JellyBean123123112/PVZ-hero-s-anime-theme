function mkCard(def){return{...def,uid:Math.random().toString(36).slice(2),curHP:def.hp}}

function buildGameDeck(){
  // exclude evolved forms (isEvolved:true) — they enter via evolution only
  const src=CARDS.filter(c=>(c.type==='plant'||c.type==='trick-plant')&&!c.isEvolved);
  const d=[];
