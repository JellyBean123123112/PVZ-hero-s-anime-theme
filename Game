  document.getElementById('gpn').textContent=hero.name;
  document.getElementById('gzp').textContent=enemy.av;
  document.getElementById('gzn').textContent=enemy.name;
  Object.assign(G,{
    turn:'plant',phase:'play',turnNum:1,sun:1,brains:1,
