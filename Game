function gainSuperCharge(n=1){
  if(G.superUsed)return;
  G.superCharge=Math.min(G.superCharge+n,3);
  updateSuperBtn();
}

function updateSuperBtn(){
  const btn=document.getElementById('superbtn');
  if(!btn)return;
  const ready=G.superCharge>=3&&!G.superUsed&&G.turn==='plant'&&!G.locked;
  btn.disabled=!ready;
  btn.classList.toggle('ready',ready);
  btn.textContent=G.superUsed?'⚡ USED':`⚡ ${G.superCharge}/3`;
}

function useSuper(){
  if(G.superCharge<3||G.superUsed||G.locked||G.turn!=='plant')return;
  const hero=HEROES.find(h=>h.id===G.heroId)||HEROES[0];
  G.superUsed=true;G.superCharge=3;

  switch(hero.id){
    case 'naruto':
      G.zHP=Math.max(0,G.zHP-6);
      flashTrick('💥 RASENGAN! -6 HP!','var(--ac)');
      document.getElementById('gzp').classList.add('a-shake');
      setTimeout(()=>document.getElementById('gzp').classList.remove('a-shake'),400);
      break;
    case 'gojo':
      G.gojoShield=true; // block all damage this combat
      flashTrick('🌀 INFINITY ACTIVE!','var(--bl)');
      notify('Infinity — immune this combat','var(--bl)');
      break;
    case 'rem':
      G.pRow.forEach(c=>{if(c)c.atk+=2});
      flashTrick('💙 MORNING STAR! All allies +2 ATK','var(--gr)');
      break;
    default:
      G.pHP=Math.min(G.pHP+5,G.pHPmax);
      flashTrick('⚡ Super Power!','var(--ac)');
  }
  renderGame();updateSuperBtn();
}

