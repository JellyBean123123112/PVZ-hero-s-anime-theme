function showBanner(l1,l2,color){
  const el=document.getElementById('tbanner');
  el.innerHTML=`<div>${l1}</div><div style="font-size:13px;letter-spacing:3px;opacity:.65;margin-top:3px">${l2}</div>`;
  el.style.color=color;el.classList.remove('show');void el.offsetWidth;el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),1700);
}

let notifTimer=null;
function notify(msg,color='#fff'){
  const el=document.getElementById('notif');
  el.textContent=msg;el.style.color=color;
  el.classList.add('show');
  clearTimeout(notifTimer);
  notifTimer=setTimeout(()=>el.classList.remove('show'),1600);
}
