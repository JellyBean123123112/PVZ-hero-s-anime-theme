<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,viewport-fit=cover,user-scalable=no">
<title>Anime Heroes</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap');

:root{
–bg:#0b0b0f;–s1:#13131a;–s2:#1a1a24;–s3:#21212e;
–b1:#252535;–b2:#333348;
–tx:#e4e4f0;–mu:#58586e;
–ac:#c8a96e;–acg:#c8a96e22;
–gr:#52b06a;–rd:#c86060;–bl:#6eaec8;
–nv:calc(58px + env(safe-area-inset-bottom,0px));
–cw:74px;–ch:104px;
–r:12px;
–ease:cubic-bezier(.4,0,.2,1);
–sp:cubic-bezier(.34,1.4,.64,1);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;touch-action:manipulation}
html,body{height:100%;overflow:hidden;overscroll-behavior:none}
body{background:var(–bg);color:var(–tx);font-family:‘DM Sans’,sans-serif;
display:flex;flex-direction:column;
position:fixed;inset:0;
padding-top:env(safe-area-inset-top,0px);
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:2px;height:2px}
::-webkit-scrollbar-thumb{background:var(–b2);border-radius:1px}

/* ═══════════════ TAB SYSTEM ═══════════════ */
#app{flex:1;overflow:hidden;min-height:0}
#vp{display:flex;width:600%;height:100%;transition:transform .38s var(–ease);will-change:transform}
.tab{width:16.6667%;height:100%;overflow-y:auto;overflow-x:hidden;flex-shrink:0;
display:flex;flex-direction:column;overscroll-behavior-y:contain;
padding-bottom:calc(var(–nv) + 8px)}

/* ═══════════════ BOTTOM NAV ═══════════════ */
#nav{
height:var(–nv);background:var(–s1);
border-top:1px solid var(–b1);
display:flex;align-items:flex-start;position:relative;flex-shrink:0;z-index:50;
padding-bottom:env(safe-area-inset-bottom,0px);
}
#npill{
position:absolute;top:6px;height:42px;
border-radius:10px;background:var(–acg);border:1px solid #c8a96e20;
transition:left .32s var(–sp),width .32s var(–sp);pointer-events:none;
}
.nb{
flex:1;background:none;border:none;
display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
cursor:pointer;height:54px;z-index:1;transition:transform .14s var(–sp);
}
.nb:active{transform:scale(.86)}
.nbi{font-size:18px;transition:transform .26s var(–sp),filter .26s;line-height:1}
.nbl{font-size:9px;font-weight:600;letter-spacing:.5px;color:var(–mu);transition:color .2s;text-transform:uppercase}
.nb.on .nbi{transform:translateY(-2px) scale(1.15);filter:drop-shadow(0 0 5px var(–ac))}
.nb.on .nbl{color:var(–ac)}

/* ═══════════════ SHARED ═══════════════ */
.ph{padding:16px 16px 0;flex-shrink:0}
.pt{font-family:‘Cinzel’,serif;font-size:19px;font-weight:900;letter-spacing:3px;color:var(–ac)}
.ps{font-size:10px;letter-spacing:3px;color:var(–mu);text-transform:uppercase;margin-top:2px}
.sec{font-size:9px;letter-spacing:3px;color:var(–mu);text-transform:uppercase;padding:14px 16px 6px}

/* ═══════════════ HOME ═══════════════ */
.hbanner{
margin:14px 16px 0;
background:linear-gradient(135deg,#191928,#111119);
border:1px solid var(–b1);border-radius:var(–r);
padding:20px 18px;display:flex;align-items:center;justify-content:space-between;
position:relative;overflow:hidden;
}
.hbanner::before{content:’’;position:absolute;inset:0;
background:radial-gradient(ellipse 70% 100% at 88% 50%,#c8a96e0c,transparent 70%)}
.hb-text{position:relative;z-index:1}
.hb-eye{font-size:9px;letter-spacing:4px;color:var(–ac);text-transform:uppercase;opacity:.55;margin-bottom:5px}
.hb-title{font-family:‘Cinzel’,serif;font-size:26px;font-weight:900;letter-spacing:5px;color:var(–ac);line-height:1;text-shadow:0 0 24px #c8a96e28}
.hb-sub{font-size:9px;color:var(–mu);letter-spacing:4px;text-transform:uppercase;margin-top:6px}
.hb-art{font-size:48px;position:relative;z-index:1;animation:float 3s ease-in-out infinite;filter:drop-shadow(0 4px 10px #c8a96e28)}
@keyframes float{0%,100%{transform:translateY(0) rotate(0)}50%{transform:translateY(-6px) rotate(3deg)}}

.pbtn{
margin:10px 16px 0;
background:linear-gradient(135deg,#d4b478,#c8a96e,#b8954a);
border:none;color:#1a1000;font-family:‘DM Sans’,sans-serif;
font-size:13px;font-weight:700;letter-spacing:3px;text-transform:uppercase;
padding:15px;border-radius:10px;cursor:pointer;width:calc(100% - 32px);
transition:transform .16s var(–sp),box-shadow .16s;
box-shadow:0 4px 18px #c8a96e22;position:relative;overflow:hidden;
}
.pbtn::before{content:’’;position:absolute;inset:0;background:linear-gradient(180deg,#ffffff18,transparent);pointer-events:none}
.pbtn:active{transform:scale(.96)}

.hgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:10px 16px 0}
.htile{
background:var(–s1);border:1px solid var(–b1);border-radius:10px;
padding:14px;cursor:pointer;transition:all .18s;position:relative;overflow:hidden;
}
.htile:active{transform:scale(.96)}
.htile-wide{grid-column:1/-1;display:flex;align-items:center;gap:10px}
.htile-wide .hti{font-size:22px;flex-shrink:0}
.htile-wide .htb{flex:1}
.htile-wide .hta{font-size:20px;color:var(–mu)}
.ht-ico{font-size:24px;margin-bottom:6px}
.ht-lbl{font-size:13px;font-weight:600}
.ht-sub{font-size:10px;color:var(–mu);margin-top:2px}
.ht-sub.acc{color:var(–ac);font-weight:600}

.sgrid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:0 16px}
.sc{background:var(–s1);border:1px solid var(–b1);border-radius:10px;padding:12px 8px;
display:flex;flex-direction:column;align-items:center;gap:2px;position:relative;overflow:hidden}
.sc::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(–ac),transparent);opacity:.4}
.sn{font-family:‘Cinzel’,serif;font-size:20px;font-weight:700;color:var(–ac)}
.sl{font-size:9px;letter-spacing:2px;color:var(–mu);text-transform:uppercase}

.mlist{padding:0 16px 4px;display:flex;flex-direction:column;gap:7px}
.mi{background:var(–s1);border:1px solid var(–b1);border-radius:10px;
padding:11px 13px;display:flex;align-items:center;gap:11px;
position:relative;overflow:hidden}
.mi::before{content:’’;position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:0 2px 2px 0}
.mi.w::before{background:var(–gr)}
.mi.l::before{background:var(–rd)}
.mi-i{font-size:17px;flex-shrink:0}
.mi-t{flex:1;min-width:0}
.mi-name{font-size:12px;font-weight:600}
.mi-sub{font-size:10px;color:var(–mu);margin-top:1px}
.mbadge{font-size:9px;font-weight:700;letter-spacing:1px;padding:3px 7px;border-radius:6px;flex-shrink:0}
.mbadge.w{background:#52b06a18;color:var(–gr)}
.mbadge.l{background:#c8606018;color:var(–rd)}

/* ═══════════════ HEROES ═══════════════ */
.hlist{padding:12px 16px 4px;display:flex;flex-direction:column;gap:9px}
.hrow{
background:var(–s1);border:1px solid var(–b1);border-radius:var(–r);
padding:13px;display:flex;align-items:center;gap:11px;
cursor:pointer;transition:all .2s var(–ease);position:relative;overflow:hidden;
}
.hrow::before{content:’’;position:absolute;left:0;top:0;bottom:0;width:3px;
background:var(–ac);transform:scaleY(0);transform-origin:center;
transition:transform .22s var(–sp);border-radius:0 2px 2px 0}
.hrow:active{transform:scale(.98)}
.hrow.sel{border-color:var(–ac);background:var(–s2);box-shadow:0 0 0 1px var(–ac)}
.hrow.sel::before{transform:scaleY(1)}
.hav{font-size:32px;flex-shrink:0;transition:transform .2s var(–sp)}
.hrow:active .hav{transform:scale(1.1)}
.hinf{flex:1;min-width:0}
.hnam{font-family:‘Cinzel’,serif;font-size:13px;font-weight:700}
.htag{display:inline-block;margin-top:2px;font-size:8px;letter-spacing:2px;text-transform:uppercase;padding:2px 7px;border-radius:20px}
.htag.p{background:#52b06a18;color:var(–gr)}
.htag.z{background:#c8606018;color:var(–rd)}
.hdesc{font-size:10px;color:var(–mu);margin-top:3px;line-height:1.4}
.hpow{font-size:10px;color:var(–bl);margin-top:2px}
.harr{color:var(–mu);font-size:16px;flex-shrink:0;transition:transform .2s var(–sp),color .2s}
.hrow.sel .harr{transform:translateX(3px);color:var(–ac)}

.bwrap{padding:0 16px 12px;flex-shrink:0}
.bbtn{width:100%;background:var(–ac);border:none;color:#1a1000;
font-family:‘DM Sans’,sans-serif;font-size:13px;font-weight:700;
letter-spacing:3px;text-transform:uppercase;padding:15px;border-radius:10px;
cursor:pointer;transition:all .2s var(–sp)}
.bbtn:active{transform:scale(.97)}
.bbtn:disabled{opacity:.3;cursor:not-allowed;transform:none}

/* ═══════════════ DECK ═══════════════ */
.dfilt{display:flex;gap:6px;padding:10px 16px 0;flex-shrink:0}
.dfb{flex:1;background:var(–s1);border:1px solid var(–b1);border-radius:8px;
padding:7px 4px;font-family:‘DM Sans’,sans-serif;font-size:10px;font-weight:600;
letter-spacing:1px;color:var(–mu);cursor:pointer;transition:all .16s var(–sp);text-transform:uppercase}
.dfb.on{background:var(–acg);border-color:var(–ac);color:var(–ac)}
.dfb:active{transform:scale(.93)}

.dpool{flex:1;overflow-y:auto;padding:10px 16px;overscroll-behavior-y:contain;min-height:0}
.cpool{display:grid;grid-template-columns:repeat(auto-fill,minmax(82px,1fr));gap:8px}

.pi{position:relative;cursor:pointer}
.pi .card{width:100%;height:auto;aspect-ratio:.72;transition:transform .16s var(–sp),opacity .2s}
.pi:active .card{transform:scale(.92)}
.pi.maxed .card{opacity:.38}
.pbadge{
position:absolute;top:3px;right:3px;z-index:5;
background:var(–s1);border:1px solid var(–b2);
border-radius:5px;padding:1px 5px;
font-size:9px;font-weight:700;font-family:‘Cinzel’,serif;color:var(–ac);
pointer-events:none;transition:all .18s var(–sp);
}
.pi.has .pbadge{background:var(–acg);border-color:var(–ac)}
.pi.maxed .pbadge{background:#c8606020;border-color:var(–rd);color:var(–rd)}

@keyframes ripple{0%{transform:scale(0);opacity:.5}100%{transform:scale(3);opacity:0}}
.prpl{position:absolute;inset:0;border-radius:8px;pointer-events:none;overflow:hidden;z-index:10}
.prpl::after{content:’’;position:absolute;top:50%;left:50%;
width:60%;height:60%;border-radius:50%;
background:var(–ac);transform:scale(0);
animation:ripple .35s ease forwards;
margin:-30% 0 0 -30%}

.dtray{background:var(–s1);border-top:1px solid var(–b1);padding:10px 16px 12px;flex-shrink:0;max-height:44%}
.dthdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:7px}
.dttl{font-family:‘Cinzel’,serif;font-size:12px;font-weight:700;color:var(–ac)}
.dthr{display:flex;align-items:center;gap:10px}
.dtct{font-size:11px;color:var(–mu)}
.dtcl{background:none;border:none;font-size:10px;color:var(–mu);cursor:pointer;letter-spacing:1px;font-family:‘DM Sans’,sans-serif;padding:2px 0;transition:color .14s}
.dtcl:hover{color:var(–rd)}
.dtbar{height:3px;background:var(–b1);border-radius:2px;overflow:hidden;margin-bottom:6px}
.dtfil{height:100%;background:var(–ac);border-radius:2px;transition:width .35s var(–sp)}
.dtlbls{display:flex;justify-content:space-between;margin-top:3px;margin-bottom:8px}
.dtlbl{font-size:9px;color:var(–mu);letter-spacing:1px}
.dtlbl.ok{color:var(–gr)}
.dtlbl.warn{color:var(–rd)}

.dklist{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:4px;max-height:130px;margin-bottom:8px}
@keyframes chipIn{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:none}}
.dkrow{display:flex;align-items:center;gap:8px;background:var(–s2);
border:1px solid var(–b1);border-radius:8px;padding:7px 9px;
animation:chipIn .2s var(–sp) both}
.dkart{font-size:16px;flex-shrink:0}
.dkname{flex:1;font-size:11px;font-weight:600;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.dkcost{font-size:9px;font-weight:700;color:var(–ac);background:var(–acg);border-radius:4px;padding:2px 5px;flex-shrink:0}
.dkctl{display:flex;align-items:center;gap:3px;flex-shrink:0}
.dkbtn{width:22px;height:22px;border-radius:5px;border:1px solid var(–b2);
background:var(–s1);color:var(–tx);font-size:13px;
display:flex;align-items:center;justify-content:center;
cursor:pointer;transition:all .14s;line-height:1}
.dkbtn:active{transform:scale(.86)}
.dkbtn.m:hover{border-color:var(–rd);color:var(–rd)}
.dkbtn.p:hover{border-color:var(–gr);color:var(–gr)}
.dkbtn:disabled{opacity:.2;cursor:not-allowed}
.dkcnt{font-family:‘Cinzel’,serif;font-size:12px;font-weight:700;color:var(–ac);min-width:14px;text-align:center}

.dtsave{width:100%;border:none;color:#1a1000;
font-family:‘DM Sans’,sans-serif;font-size:12px;font-weight:700;
letter-spacing:3px;text-transform:uppercase;padding:12px;border-radius:9px;cursor:pointer;
transition:all .18s var(–sp)}
.dtsave.ok{background:var(–ac)}
.dtsave.no{background:var(–b2);color:var(–mu);cursor:not-allowed}
.dtsave:active{transform:scale(.97)}

/* ═══════════════ CHESTS ═══════════════ */
.cgrid{padding:12px 16px 4px;display:grid;grid-template-columns:1fr 1fr;gap:10px}
.ccard{background:var(–s1);border:1px solid var(–b1);border-radius:var(–r);
padding:18px 12px;display:flex;flex-direction:column;align-items:center;gap:7px;
cursor:pointer;transition:all .2s var(–sp);position:relative;overflow:hidden}
.ccard::after{content:’’;position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,#c8a96e08,transparent 70%);opacity:0;transition:opacity .25s}
.ccard:hover{border-color:var(–ac);transform:translateY(-3px);box-shadow:0 10px 24px #00000050}
.ccard:hover::after{opacity:1}
.ccard:active{transform:scale(.94)}
.cico{font-size:38px;transition:transform .26s var(–sp)}
.ccard:hover .cico{transform:translateY(-4px) rotate(-6deg)}
.cname{font-family:‘Cinzel’,serif;font-size:12px;font-weight:700}
.ccost{font-size:11px;color:var(–ac);font-weight:600}
.cdesc{font-size:10px;color:var(–mu);text-align:center;line-height:1.5}

#cov{position:fixed;inset:0;z-index:300;background:#000000cc;backdrop-filter:blur(12px);
display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;
opacity:0;pointer-events:none;transition:opacity .28s}
#cov.show{opacity:1;pointer-events:all}
.cvtitle{font-family:‘Cinzel’,serif;font-size:17px;font-weight:700;color:var(–ac);letter-spacing:3px}
.rvcards{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
.rvcard{opacity:0;transform:translateY(18px) scale(.82);transition:all .35s var(–sp)}
.rvcard.pop{opacity:1;transform:none}
.rvcls{background:var(–ac);border:none;color:#1a1000;font-family:‘DM Sans’,sans-serif;
font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;
padding:13px 34px;border-radius:10px;cursor:pointer;
opacity:0;transform:translateY(6px);transition:all .28s .45s var(–sp)}
#cov.show .rvcls{opacity:1;transform:none}

/* ═══════════════ SETTINGS ═══════════════ */
.slist{padding:12px 16px 4px;display:flex;flex-direction:column;gap:7px}
.ssec{font-size:9px;letter-spacing:3px;color:var(–mu);text-transform:uppercase;padding:6px 2px 3px}
.srow{background:var(–s1);border:1px solid var(–b1);border-radius:10px;padding:13px 15px;display:flex;align-items:center;justify-content:space-between}
.slbl{font-size:13px;font-weight:500}
.ssub{font-size:10px;color:var(–mu);margin-top:2px}
.tog{width:42px;height:24px;border-radius:12px;background:var(–b2);position:relative;cursor:pointer;border:none;transition:background .22s;flex-shrink:0}
.tog::after{content:’’;position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:3px;left:3px;transition:transform .22s var(–sp);box-shadow:0 1px 4px #00000050}
.tog.on{background:var(–ac)}
.tog.on::after{transform:translateX(18px)}
.ssel{background:var(–s2);border:1px solid var(–b2);color:var(–tx);font-family:‘DM Sans’,sans-serif;font-size:11px;padding:6px 10px;border-radius:7px;cursor:pointer;outline:none}

/* ═══════════════ HISTORY TAB ═══════════════ */
.hx-empty{
display:flex;flex-direction:column;align-items:center;justify-content:center;
gap:12px;padding:60px 20px;color:var(–mu);text-align:center;
}
.hx-empty-ico{font-size:48px;opacity:.4}
.hx-empty-txt{font-size:13px;letter-spacing:1px}

.hx-list{padding:12px 16px 4px;display:flex;flex-direction:column;gap:10px}
.hx-row{
background:var(–s1);border:1px solid var(–b1);border-radius:var(–r);
padding:14px;cursor:pointer;transition:all .2s var(–ease);position:relative;overflow:hidden;
}
.hx-row::before{content:’’;position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:0 2px 2px 0}
.hx-row.w::before{background:var(–gr)}
.hx-row.l::before{background:var(–rd)}
.hx-row:active{transform:scale(.98)}
.hx-top{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.hx-avs{display:flex;align-items:center;gap:0}
.hx-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.hx-av.p{background:#52b06a18;border:1.5px solid #52b06a44}
.hx-av.z{background:#c8606018;border:1.5px solid #c8606044;margin-left:-8px}
.hx-title{flex:1;font-family:‘Cinzel’,serif;font-size:12px;font-weight:700}
.hx-badge{font-size:9px;font-weight:700;letter-spacing:1px;padding:3px 8px;border-radius:6px;flex-shrink:0}
.hx-badge.w{background:#52b06a18;color:var(–gr)}
.hx-badge.l{background:#c8606018;color:var(–rd)}
.hx-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}
.hx-stat{background:var(–s2);border-radius:7px;padding:6px 4px;text-align:center}
.hx-stat-n{font-family:‘Cinzel’,serif;font-size:14px;font-weight:700;color:var(–ac)}
.hx-stat-l{font-size:8px;letter-spacing:1px;color:var(–mu);text-transform:uppercase;margin-top:1px}
.hx-time{font-size:10px;color:var(–mu);margin-top:8px}
.hx-arrow{position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:16px;color:var(–mu)}

/* match detail sheet */
#match-detail{
position:fixed;inset:0;z-index:200;background:var(–bg);
transform:translateX(100%);transition:transform .36s var(–sp);
display:flex;flex-direction:column;
padding-top:env(safe-area-inset-top,0px);
}
#match-detail.open{transform:translateX(0)}
.md-header{
display:flex;align-items:center;gap:12px;
padding:14px 16px;background:var(–s1);border-bottom:1px solid var(–b1);flex-shrink:0;
}
.md-back{background:none;border:none;color:var(–mu);font-size:20px;cursor:pointer;padding:4px;line-height:1}
.md-back:hover{color:var(–tx)}
.md-title{font-family:‘Cinzel’,serif;font-size:15px;font-weight:700;color:var(–ac);letter-spacing:2px}
.md-body{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:16px}

.md-result-banner{
border-radius:var(–r);padding:20px;display:flex;align-items:center;gap:16px;
position:relative;overflow:hidden;
}
.md-result-banner.w{background:linear-gradient(135deg,#1a2a1a,#111910);border:1px solid #52b06a33}
.md-result-banner.l{background:linear-gradient(135deg,#2a1a1a,#191010);border:1px solid #c8606033}
.md-result-ico{font-size:48px}
.md-result-txt{}
.md-result-label{font-family:‘Cinzel’,serif;font-size:24px;font-weight:900;letter-spacing:3px}
.md-result-label.w{color:var(–gr)}
.md-result-label.l{color:var(–rd)}
.md-result-sub{font-size:11px;color:var(–mu);margin-top:4px;letter-spacing:1px}

.md-section{font-size:9px;letter-spacing:3px;color:var(–mu);text-transform:uppercase;margin-bottom:8px}
.md-stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.md-stat{background:var(–s1);border:1px solid var(–b1);border-radius:10px;padding:12px 8px;text-align:center}
.md-stat-n{font-family:‘Cinzel’,serif;font-size:20px;font-weight:700;color:var(–ac)}
.md-stat-l{font-size:9px;letter-spacing:2px;color:var(–mu);text-transform:uppercase;margin-top:2px}

/* player vs enemy side by side */
.md-vs{display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:center}
.md-hero-card{background:var(–s1);border:1px solid var(–b1);border-radius:10px;padding:14px;text-align:center}
.md-hero-av{font-size:36px;margin-bottom:6px}
.md-hero-name{font-family:‘Cinzel’,serif;font-size:11px;font-weight:700}
.md-hero-hp{font-size:10px;color:var(–mu);margin-top:3px}
.md-vs-label{font-family:‘Cinzel’,serif;font-size:13px;font-weight:700;color:var(–mu);text-align:center}

/* cards played list */
.md-cards-played{display:flex;flex-direction:column;gap:6px}
.md-card-row{
background:var(–s1);border:1px solid var(–b1);border-radius:8px;
padding:10px 12px;display:flex;align-items:center;gap:10px;
}
.md-card-art{font-size:20px;flex-shrink:0}
.md-card-info{flex:1}
.md-card-name{font-size:12px;font-weight:600}
.md-card-type{font-size:9px;letter-spacing:2px;color:var(–mu);text-transform:uppercase;margin-top:2px}
.md-card-cost{font-size:10px;font-weight:700;color:var(–ac);background:var(–acg);border-radius:4px;padding:2px 7px;flex-shrink:0}

.md-timeline{display:flex;flex-direction:column;gap:0}
.md-turn{display:flex;gap:10px;align-items:flex-start;padding:8px 0;border-bottom:1px solid var(–b1)}
.md-turn:last-child{border-bottom:none}
.md-turn-num{font-family:‘Cinzel’,serif;font-size:11px;font-weight:700;color:var(–ac);width:20px;flex-shrink:0;padding-top:1px}
.md-turn-events{flex:1;display:flex;flex-direction:column;gap:3px}
.md-event{font-size:11px;color:var(–mu);line-height:1.5}
.md-event.dmg{color:var(–rd)}
.md-event.play{color:var(–tx)}
.md-event.kill{color:var(–gr)}

.md-btn{
width:100%;background:var(–ac);border:none;color:#1a1000;
font-family:‘DM Sans’,sans-serif;font-size:13px;font-weight:700;
letter-spacing:3px;text-transform:uppercase;padding:15px;border-radius:10px;
cursor:pointer;transition:all .2s var(–sp);
}
.md-btn:active{transform:scale(.97)}
.md-btn-sec{
width:100%;background:none;border:1px solid var(–b2);color:var(–mu);
font-family:‘DM Sans’,sans-serif;font-size:12px;font-weight:600;
letter-spacing:2px;text-transform:uppercase;padding:12px;border-radius:10px;
cursor:pointer;transition:all .18s;margin-top:8px;
}
.md-btn-sec:active{background:var(–s2)}

/* multiplayer prep badge */
.mp-badge{
background:linear-gradient(135deg,#1a1a30,#12122a);
border:1px solid #6060cc44;border-radius:8px;
padding:10px 14px;display:flex;align-items:center;gap:10px;
margin-bottom:4px;
}
.mp-badge-ico{font-size:20px}
.mp-badge-txt{font-size:11px;color:#9090cc;line-height:1.5}
.mp-badge-label{font-size:9px;letter-spacing:3px;color:#6060cc;text-transform:uppercase;margin-bottom:2px}

/* ═══════════════ GAME OVERLAY ═══════════════ */
#game{
position:fixed;inset:0;z-index:100;
background:linear-gradient(180deg,#0d0d16 0%,#0b0b0f 100%);
transform:translateY(100%);transition:transform .46s var(–sp);
display:flex;flex-direction:column;
padding-top:env(safe-area-inset-top,0px);
padding-bottom:env(safe-area-inset-bottom,0px);
}
#game.open{transform:translateY(0)}

/* compact topbar — 2 rows */
#gtop{
display:flex;flex-direction:column;
background:linear-gradient(180deg,#151522,#111118);
border-bottom:1px solid var(–b1);flex-shrink:0;
}
#gtop-r1{
display:grid;grid-template-columns:1fr auto 1fr;align-items:center;
padding:8px 12px 4px;gap:4px;
}
#gtop-r2{
display:flex;align-items:center;justify-content:center;gap:8px;
padding:4px 12px 8px;border-top:1px solid #ffffff07;
}
.ghud{display:flex;align-items:center;gap:6px}
.ghud.r{flex-direction:row-reverse}
.gport{width:34px;height:34px;border-radius:50%;
display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.gport.p{background:#52b06a18;border:1.5px solid #52b06a44;box-shadow:0 0 8px #52b06a15}
.gport.z{background:#c8606018;border:1.5px solid #c8606044;box-shadow:0 0 8px #c8606015}
.gnam{font-family:‘Cinzel’,serif;font-size:10px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:80px}
.gnam.p{color:var(–gr)}
.gnam.z{color:var(–rd)}
.ghprow{display:flex;align-items:center;gap:4px;margin-top:2px}
.ghpbar{width:52px;height:3px;background:var(–b1);border-radius:2px;overflow:hidden}
.ghpfil{height:100%;border-radius:2px;transition:width .45s var(–ease)}
.ghpfil.p{background:linear-gradient(90deg,#3a9e50,var(–gr))}
.ghpfil.z{background:linear-gradient(90deg,#9e3a3a,var(–rd))}
.ghptxt{font-size:9px;color:var(–mu)}
.gctr{display:flex;flex-direction:column;align-items:center;gap:2px}
.gtbadge{font-family:‘Cinzel’,serif;font-size:10px;font-weight:700;
letter-spacing:2px;padding:3px 10px;border-radius:6px;border:1px solid;transition:all .3s;white-space:nowrap}
.gtbadge.p{color:var(–gr);border-color:#52b06a40;background:#52b06a0a}
.gtbadge.z{color:var(–rd);border-color:#c8606040;background:#c8606008}
.gresrow{display:flex;gap:8px;align-items:center}
.gres{display:flex;align-items:center;gap:3px;font-size:12px;font-weight:700}
.grv.s{color:var(–ac)}
.grv.b{color:var(–rd)}
.etb{background:var(–s2);border:1px solid var(–b2);color:var(–mu);
font-family:‘DM Sans’,sans-serif;font-size:9px;font-weight:600;
letter-spacing:2px;text-transform:uppercase;
padding:7px 12px;border-radius:7px;cursor:pointer;transition:all .16s;white-space:nowrap}
.etb:hover{border-color:var(–bl);color:var(–bl)}
.etb:active{transform:scale(.92)}
.qb{background:none;border:none;color:var(–mu);font-size:12px;cursor:pointer;padding:4px 6px;transition:color .14s;line-height:1;flex-shrink:0}
.qb:hover{color:var(–rd)}

/* battlefield */
#bf{flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative;min-height:0}
#bf::before{content:’’;position:absolute;inset:0;
background:radial-gradient(ellipse 90% 35% at 50% 20%,#c8606008,transparent 65%),
radial-gradient(ellipse 90% 35% at 50% 80%,#52b06a08,transparent 65%);
pointer-events:none;z-index:0}
.lrow{flex:1;display:grid;grid-template-columns:repeat(5,1fr);gap:4px;padding:4px 8px;position:relative;z-index:1;min-height:0}
.lcell{
background:linear-gradient(160deg,var(–s1),#111118);
border:1px solid var(–b1);border-radius:9px;
display:flex;align-items:center;justify-content:center;
position:relative;min-height:0;transition:all .2s var(–ease);overflow:hidden;
}
.lcell::after{content:’’;position:absolute;inset:0;
background:linear-gradient(180deg,#ffffff05 0%,transparent 50%);pointer-events:none}
.lcell.drop{border-color:var(–gr);border-style:dashed;background:#52b06a10;box-shadow:inset 0 0 12px #52b06a12}
.lcell.dropon{border-color:var(–gr);border-style:solid;background:#52b06a22;box-shadow:inset 0 0 16px #52b06a20,0 0 10px #52b06a25;transform:scale(1.04)}
.lnum{position:absolute;bottom:3px;right:4px;font-size:7px;color:var(–b2);font-family:‘Cinzel’,serif;opacity:.7}

@keyframes cland{from{transform:scale(.7) translateY(-12px);opacity:0}to{transform:none;opacity:1}}
.clnd{animation:cland .28s var(–sp) both}

.tstrip{flex:0 0 24px;background:linear-gradient(90deg,var(–bg),var(–s1),var(–bg));
border-top:1px solid var(–b1);border-bottom:1px solid var(–b1);
display:flex;align-items:center;gap:4px;padding:0 10px;position:relative;z-index:1}
.tslbl{font-size:8px;letter-spacing:3px;color:var(–mu);text-transform:uppercase;margin-right:4px;opacity:.5}
.tslot{flex:1;height:12px;border-radius:3px;border:1px dashed var(–b1);
display:flex;align-items:center;justify-content:center;font-size:7px;color:var(–b2);letter-spacing:1px}

/* hand */
#hand{display:flex;flex-direction:column;flex-shrink:0;
background:linear-gradient(0deg,#131320,var(–bg));border-top:1px solid var(–b1)}
#hlbl{display:flex;align-items:center;justify-content:space-between;
padding:4px 14px 0;font-size:8px;letter-spacing:2px;color:var(–mu);text-transform:uppercase}
#hcards{display:flex;align-items:flex-end;gap:4px;
padding:4px 12px 10px;min-height:112px;overflow-x:auto;overflow-y:visible;
scrollbar-width:none;touch-action:none}
#hcards::-webkit-scrollbar{display:none}
#hcards .card:nth-child(1){transform:rotate(-5deg) translateY(6px)}
#hcards .card:nth-child(2){transform:rotate(-2.5deg) translateY(3px)}
#hcards .card:nth-child(3){transform:rotate(0deg)}
#hcards .card:nth-child(4){transform:rotate(2.5deg) translateY(3px)}
#hcards .card:nth-child(5){transform:rotate(5deg) translateY(6px)}
#hcards .card:nth-child(6){transform:rotate(7deg) translateY(9px)}
#hcards .card:nth-child(n+7){transform:rotate(8.5deg) translateY(11px)}
#hcards .card.ghost{opacity:.22;transform:none !important;pointer-events:none;filter:blur(1px)}

/* ═══════════════ DRAG GHOST ═══════════════ */
#dg{position:fixed;z-index:500;pointer-events:none;opacity:0;transition:opacity .1s;
filter:drop-shadow(0 14px 28px #00000099)}
#dg.vis{opacity:.93}

/* ═══════════════ CARDS ═══════════════ */
.card{
width:var(–cw);height:var(–ch);border-radius:9px;
display:flex;flex-direction:column;cursor:pointer;
transition:transform .16s var(–sp);
position:relative;overflow:hidden;flex-shrink:0;user-select:none;
}
.card::before{content:’’;position:absolute;inset:0;
background:linear-gradient(180deg,#ffffff0a 0%,transparent 38%);
pointer-events:none;z-index:1;border-radius:9px}
.card.pc{background:linear-gradient(150deg,#192818,#111610);border:1px solid #52b06a44}
.card.zc{background:linear-gradient(150deg,#271818,#160f0f);border:1px solid #c8606044}
.card.tc{background:linear-gradient(150deg,#181c28,#10111a);border:1px solid #6eaec844}
.card.tc.zc{background:linear-gradient(150deg,#271818,#160f0f);border:1px solid #c8606044}
.cpip{position:absolute;top:4px;left:4px;width:17px;height:17px;border-radius:50%;
display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;z-index:2;box-shadow:0 1px 4px #00000055}
.pc .cpip{background:linear-gradient(135deg,#d4b478,#c8a96e);color:#1a1000}
.zc .cpip{background:linear-gradient(135deg,#d47070,#c86060);color:#fff}
.tc .cpip,.tc.zc .cpip{background:linear-gradient(135deg,#80c0d8,#6eaec8);color:#001824}
.cart{flex:1;display:flex;align-items:center;justify-content:center;font-size:28px;margin-top:4px;filter:drop-shadow(0 2px 4px #00000055)}
.cnam{font-family:‘Cinzel’,serif;font-size:7px;font-weight:700;text-align:center;padding:0 2px;line-height:1.2;color:#8080a0;position:relative;z-index:1}
.csts{display:flex;justify-content:space-between;padding:2px 5px 4px;font-size:9px;font-weight:700;position:relative;z-index:1}
.catk{color:var(–ac)}
.cdef{color:var(–gr)}
.zc .cdef,.tc.zc .cdef{color:var(–rd)}
.ctag{font-size:7px;color:var(–bl);text-align:center;padding:0 3px 3px;line-height:1.3;position:relative;z-index:1}

/* trick flash overlay */
@keyframes trickFlash{0%{opacity:0}20%{opacity:1}80%{opacity:.8}100%{opacity:0}}
.trick-overlay{
position:fixed;inset:0;z-index:200;pointer-events:none;
display:flex;align-items:center;justify-content:center;
font-family:‘Cinzel’,serif;font-size:32px;font-weight:900;
letter-spacing:3px;opacity:0;
animation:trickFlash .8s ease forwards;
text-shadow:0 2px 20px currentColor;
}

/* ═══════════════ INFO SHEET ═══════════════ */
#info-sheet{position:fixed;inset:0;z-index:400;background:#000000b0;backdrop-filter:blur(10px);
display:flex;align-items:flex-end;justify-content:center;
opacity:0;pointer-events:none;transition:opacity .22s}
#info-sheet.show{opacity:1;pointer-events:all}
.icw{background:var(–s1);border:1px solid var(–b1);
border-radius:18px 18px 0 0;padding:16px 22px 28px;
width:100%;max-width:400px;
transform:translateY(100%);transition:transform .3s var(–sp);
display:flex;flex-direction:column;align-items:center;gap:11px}
#info-sheet.show .icw{transform:translateY(0)}
.ihandle{width:34px;height:4px;background:var(–b2);border-radius:2px;margin-bottom:2px}
.ibig{transform:scale(1.25);transform-origin:top center;margin:8px 0 16px}
.iname{font-family:‘Cinzel’,serif;font-size:17px;font-weight:700;color:var(–ac)}
.itype{font-size:9px;letter-spacing:3px;color:var(–mu);text-transform:uppercase}
.istats{display:flex;gap:22px;margin-top:2px}
.istat{display:flex;flex-direction:column;align-items:center;gap:1px}
.isv{font-family:‘Cinzel’,serif;font-size:21px;font-weight:700}
.isl{font-size:9px;letter-spacing:2px;color:var(–mu);text-transform:uppercase}
.idesc{font-size:12px;color:var(–mu);text-align:center;line-height:1.6;max-width:270px}
.ipbtn{width:100%;background:var(–ac);border:none;color:#1a1000;
font-family:‘DM Sans’,sans-serif;font-size:13px;font-weight:700;
letter-spacing:3px;text-transform:uppercase;padding:14px;border-radius:10px;cursor:pointer;
transition:all .2s var(–sp);margin-top:2px}
.ipbtn:active{transform:scale(.97)}
.ipbtn:disabled{opacity:.3;cursor:not-allowed;transform:none}
.icls{background:none;border:1px solid var(–b2);color:var(–mu);font-family:‘DM Sans’,sans-serif;font-size:11px;padding:9px;border-radius:8px;cursor:pointer;width:100%;transition:all .16s}
.icls:active{background:var(–s2)}

/* ═══════════════ LANE SHEET ═══════════════ */
#lane-sheet{position:fixed;inset:0;z-index:400;background:#000000b0;backdrop-filter:blur(10px);
display:flex;align-items:flex-end;justify-content:center;
opacity:0;pointer-events:none;transition:opacity .22s}
#lane-sheet.show{opacity:1;pointer-events:all}
.lsw{background:var(–s1);border:1px solid var(–b1);
border-radius:18px 18px 0 0;padding:18px 18px 28px;
width:100%;max-width:400px;
transform:translateY(100%);transition:transform .3s var(–sp)}
#lane-sheet.show .lsw{transform:translateY(0)}
.lstitle{font-family:‘Cinzel’,serif;font-size:13px;font-weight:700;color:var(–ac);letter-spacing:2px;text-align:center;margin-bottom:12px}
.lslanes{display:grid;grid-template-columns:repeat(5,1fr);gap:7px}
.lsl{background:var(–s2);border:1px solid var(–b2);border-radius:10px;
padding:10px 5px;display:flex;flex-direction:column;align-items:center;gap:5px;
cursor:pointer;transition:all .16s var(–sp)}
.lsl:active{transform:scale(.92)}
.lsl.open{border-color:var(–gr)}
.lsl.open:hover{background:#52b06a14}
.lsl.taken{opacity:.32;cursor:not-allowed}
.lsl-num{font-family:‘Cinzel’,serif;font-size:15px;font-weight:700;color:var(–ac)}
.lsl-art{font-size:18px}
.lsl-st{font-size:7px;letter-spacing:1px;text-transform:uppercase;color:var(–mu)}
.lsl.open .lsl-st{color:var(–gr)}
.lscancel{margin-top:10px;width:100%;background:none;border:1px solid var(–b2);color:var(–mu);
font-family:‘DM Sans’,sans-serif;font-size:11px;padding:11px;border-radius:9px;cursor:pointer;transition:all .16s}
.lscancel:active{background:var(–s2)}

/* ═══════════════ COMBAT FX ═══════════════ */
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-5px)}60%{transform:translateX(5px)}80%{transform:translateX(-3px)}}
@keyframes atkp{0%,100%{transform:translateY(0)}40%{transform:translateY(-13px)}}
@keyframes atkz{0%,100%{transform:translateY(0)}40%{transform:translateY(13px)}}
@keyframes dmgpop{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-34px) scale(1.25)}}
@keyframes dieaim{0%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.15)}100%{opacity:0;transform:scale(0)}}
.a-atkp{animation:atkp .3s var(–sp) both}
.a-atkz{animation:atkz .3s var(–sp) both}
.a-shake{animation:shake .28s ease both}
.a-die{animation:dieaim .32s ease forwards}
.dmgf{position:absolute;font-family:‘Cinzel’,serif;font-size:15px;font-weight:900;
pointer-events:none;z-index:50;animation:dmgpop .75s ease forwards;
text-shadow:0 2px 5px #000}

/* ═══════════════ NOTIF & BANNER ═══════════════ */
#notif{position:fixed;bottom:calc(var(–nv) + 16px);left:50%;
transform:translateX(-50%) translateY(8px);
background:var(–s2);border:1px solid var(–b2);
font-family:‘DM Sans’,sans-serif;font-size:13px;font-weight:600;
padding:10px 18px;border-radius:20px;
pointer-events:none;opacity:0;transition:opacity .18s,transform .2s var(–sp);
white-space:nowrap;z-index:600;box-shadow:0 4px 16px #00000060}
#notif.show{opacity:1;transform:translateX(-50%) translateY(0)}

@keyframes bann{0%{opacity:0;transform:translate(-50%,-50%) scale(.7)}25%{opacity:1;transform:translate(-50%,-50%) scale(1.02)}75%{opacity:1;transform:translate(-50%,-50%) scale(1)}100%{opacity:0;transform:translate(-50%,-50%) scale(.94)}}
#tbanner{position:fixed;top:50%;left:50%;z-index:500;
font-family:‘Cinzel’,serif;font-size:26px;font-weight:900;letter-spacing:4px;
pointer-events:none;opacity:0;text-align:center;line-height:1.2;
text-shadow:0 2px 24px currentColor;white-space:nowrap}
#tbanner.show{animation:bann 1.7s ease forwards}

@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.fin{animation:fadeUp .3s var(–ease) both}

/* ═══════════════ END SCREEN ═══════════════ */
#endscreen{
position:fixed;inset:0;z-index:150;
display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;
padding:24px;
opacity:0;pointer-events:none;transition:opacity .4s;
}
#endscreen.show{opacity:1;pointer-events:all}
#endscreen::before{
content:’’;position:absolute;inset:0;
background:var(–bg);opacity:.96;
}
.es-content{
position:relative;z-index:1;
display:flex;flex-direction:column;align-items:center;gap:16px;
width:100%;max-width:340px;
}
.es-icon{font-size:64px;animation:float 2.5s ease-in-out infinite}
.es-result{
font-family:‘Cinzel’,serif;font-size:32px;font-weight:900;
letter-spacing:4px;text-align:center;line-height:1;
}
.es-sub{font-size:13px;color:var(–mu);letter-spacing:2px;text-transform:uppercase}
.es-stats{
display:grid;grid-template-columns:repeat(3,1fr);gap:8px;
width:100%;margin:8px 0;
}
.es-stat{
background:var(–s1);border:1px solid var(–b1);border-radius:10px;
padding:12px 8px;display:flex;flex-direction:column;align-items:center;gap:3px;
}
.es-stat-n{font-family:‘Cinzel’,serif;font-size:20px;font-weight:700;color:var(–ac)}
.es-stat-l{font-size:9px;letter-spacing:2px;color:var(–mu);text-transform:uppercase}
.es-btns{display:flex;flex-direction:column;gap:8px;width:100%}
.es-btn-main{
width:100%;background:var(–ac);border:none;color:#1a1000;
font-family:‘DM Sans’,sans-serif;font-size:13px;font-weight:700;
letter-spacing:3px;text-transform:uppercase;padding:15px;border-radius:10px;
cursor:pointer;transition:all .18s var(–sp);
}
.es-btn-main:active{transform:scale(.97)}
.es-btn-sec{
width:100%;background:none;border:1px solid var(–b2);color:var(–mu);
font-family:‘DM Sans’,sans-serif;font-size:12px;font-weight:600;
letter-spacing:2px;text-transform:uppercase;padding:12px;border-radius:10px;
cursor:pointer;transition:all .18s;
}
.es-btn-sec:active{background:var(–s2)}

/* ═══════════════ SUPER BUTTON ═══════════════ */
#superbtn{
background:linear-gradient(135deg,#1e1e30,#14142a);
border:1px solid #7070cc55;color:#9090ee;
font-family:‘DM Sans’,sans-serif;font-size:8px;font-weight:700;
letter-spacing:2px;text-transform:uppercase;
padding:5px 9px;border-radius:7px;cursor:pointer;transition:all .2s;
white-space:nowrap;
}
#superbtn.ready{
background:linear-gradient(135deg,#2a1a40,#1a1030);
border-color:#aa66ff88;color:#cc88ff;
box-shadow:0 0 12px #aa66ff30;
animation:superPulse 2s ease-in-out infinite;
