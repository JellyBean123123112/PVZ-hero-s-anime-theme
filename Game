  document.getElementById('lane-sheet').classList.add('show');
}

function _buildLanes(forTrick){
  const ls=document.getElementById('lslanes');ls.innerHTML='';
  for(let i=0;i<5;i++){
    const taken=!!G.pRow[i];
    let disabled=forTrick
      ?(pendTrick.summon?taken : pendTrick.buffLane?!taken : false)
      :taken;
    const lane=document.createElement('div');
    lane.className='lsl'+(disabled?' taken':' open');
    lane.innerHTML=`<div class="lsl-num">${i+1}</div>
      <div class="lsl-art">${G.pRow[i]?G.pRow[i].art:'—'}</div>
      <div class="lsl-st">${taken?'Taken':'Open'}</div>`;
    if(!disabled)lane.onclick=()=>confirmLane(i);
    ls.appendChild(lane);
  }
}

function closeLane(e){
  if(e&&e.target!==document.getElementById('lane-sheet'))return;
  document.getElementById('lane-sheet').classList.remove('show');
  pendCard=null;pendTrick=null;
}

function confirmLane(lane){
  document.getElementById('lane-sheet').classList.remove('show');
  if(!pendCard)return;
  if(pendTrick){
    // trick with target lane
    const idx=G.hand.findIndex(c=>c.uid===pendCard.uid);
    if(idx===-1){pendCard=null;pendTrick=null;return}
    G.sun-=pendCard.cost;G.hand.splice(idx,1);
    applyTrickEffect(pendTrick,pendCard,lane);
    renderGame();
  } else {
    placeCard(pendCard,lane);
  }
  pendCard=null;pendTrick=null;
}

/* ══════════════════════════════
   DRAG TO PLAY
══════════════════════════════ */
let drag={active:false,card:null,srcEl:null,startX:0,startY:0,pointerId:null};
const DG=document.getElementById('dg');

function setupDrag(el,card){
  let pt=null,moved=false;
  el.addEventListener('pointerdown',e=>{
    if(G.locked)return;
    e.preventDefault();
    moved=false;drag.startX=e.clientX;drag.startY=e.clientY;
    pt=setTimeout(()=>{if(!moved&&!G.locked)startDrag(el,card,e)},150);
  },{passive:false});
  el.addEventListener('pointermove',e=>{
    if(Math.abs(e.clientX-drag.startX)>8||Math.abs(e.clientY-drag.startY)>8){
      moved=true;
      if(!drag.active&&!G.locked){clearTimeout(pt);startDrag(el,card,e)}
    }
    if(drag.active&&drag.pointerId===e.pointerId)onMove(e);
  },{passive:false});
  el.addEventListener('pointerup',e=>{
    clearTimeout(pt);
    if(drag.active&&drag.pointerId===e.pointerId)onEnd(e);
    else if(!moved&&!G.locked)showInfo(card);
  });
  el.addEventListener('pointercancel',e=>{clearTimeout(pt);if(drag.pointerId===e.pointerId)cancelDrag()});
}

function startDrag(el,card,e){
  if(drag.active)return;
  drag={active:true,card,srcEl:el,startX:e.clientX,startY:e.clientY,pointerId:e.pointerId};
  DG.innerHTML='';
  const clone=mkCardEl(card);clone.style.pointerEvents='none';clone.style.width='74px';
  DG.style.width='74px';DG.appendChild(clone);
  posGhost(e.clientX,e.clientY);DG.classList.add('vis');
  el.classList.add('ghost');
  el.setPointerCapture(e.pointerId);
  hlDropZones(true,card);
  // show mana preview
  const mp=document.getElementById('mana-preview');
  const canAfford=G.sun>=card.cost;
  const isTrick=card.type&&card.type.startsWith('trick');
  mp.textContent=isTrick?`Trick · costs ${card.cost} ☀️`:`${card.cost} ☀️  →  ${Math.max(0,G.sun-card.cost)} remaining`;
  mp.classList.toggle('cant',!canAfford);
  mp.classList.add('show');
}

function onMove(e){
  posGhost(e.clientX,e.clientY);
  const hovered=hitCell(e.clientX,e.clientY);
  document.querySelectorAll('.lcell').forEach(c=>c.classList.remove('dropon'));
  if(hovered){
    const lane=+hovered.dataset.lane;
    const isTrick=drag.card.type&&drag.card.type.startsWith('trick');
    if(!isTrick&&!G.pRow[lane])hovered.classList.add('dropon');
  }
}

function posGhost(x,y){DG.style.left=(x-37)+'px';DG.style.top=(y-98)+'px'}

function hitCell(x,y){
  let found=null;
  document.querySelectorAll('#prow .lcell').forEach(cell=>{
    const r=cell.getBoundingClientRect();
    if(x>=r.left&&x<=r.right&&y>=r.top&&y<=r.bottom)found=cell;
  });
  return found;
}

function onEnd(e){
  const cardRef=drag.card; // save ref BEFORE cancelDrag nulls it
  const cell=hitCell(e.clientX,e.clientY);
  cancelDrag(); // always clean up first
  if(!cardRef)return;
  if(cell){
    const lane=+cell.dataset.lane;
    const isTrick=cardRef.type&&cardRef.type.startsWith('trick');
    if(isTrick){
      activateTrick(cardRef);
      return;
    }
    placeCard(cardRef,lane);
  }
}

function cancelDrag(){
  DG.classList.remove('vis');
  if(drag.srcEl)drag.srcEl.classList.remove('ghost');
  document.querySelectorAll('.lcell').forEach(c=>c.classList.remove('dropon'));
  hlDropZones(false,null);
  document.getElementById('mana-preview').classList.remove('show');
  drag={active:false,card:null,srcEl:null,startX:0,startY:0,pointerId:null};
}

function hlDropZones(on,card){
  const isTrick=card&&card.type&&card.type.startsWith('trick');
  document.querySelectorAll('#prow .lcell').forEach((c,i)=>{
    c.classList.toggle('drop',on&&!isTrick&&!G.pRow[i]);
  });
}

/* ══════════════════════════════
   PLAY LOGIC
══════════════════════════════ */
function placeCard(card,lane){
  if(G.locked||G.turn!=='plant'||G.phase!=='play')return;
  if(G.sun<card.cost){notify(`Need ${card.cost} ☀️`,'var(--ac)');return}
  if(G.pRow[lane]){notify('Lane occupied','var(--rd)');return}
  const idx=G.hand.findIndex(c=>c.uid===card.uid);
  if(idx===-1)return;
  G.sun-=card.cost;G.hand.splice(idx,1);
  G.pRow[lane]=card;
  // on-play effects
  if(card.effect){
    if(card.effect.extraSun){G.sun=Math.min(G.sun+card.effect.extraSun,10);notify(`+${card.effect.extraSun} ☀️`,'var(--ac)')}
    if(card.effect.heal){G.pHP=Math.min(G.pHP+card.effect.heal,G.pHPmax);notify(`+${card.effect.heal} HP ❤️`,'var(--gr)')}
  }
  renderGame();
}

/* ══════════════════════════════
   TURN FLOW
══════════════════════════════ */
async function endTurn(){
  if(G.locked||G.phase!=='play')return;
  G.locked=true;G.phase='combat';G.frozenZones=[];renderGame();
  await runCombat();
  if(checkWin())return;

  G.turn='zombie';G.phase='ai';
  G.brains=Math.min(G.turnNum,10);
  renderGame();showBanner('ZOMBIE TURN','AI thinking...','var(--rd)');
  await wait(1100);await aiTurn();
  G.frozenZones=[];
  await runCombat();
  if(checkWin())return;

  G.turnNum++;G.turn='plant';G.phase='play';
  G.sun=Math.min(G.turnNum,10);
  G.gojoShield=false; // shield expires each turn
  tickEvolutions();   // check for card evolutions
  // draw if hand not full
  if(G.hand.length<HAND_LIMIT)drawCard();
  else notify('Hand full — discard something','var(--rd)');
  // gain super charge each new turn
  gainSuperCharge(1);
  G.locked=false;renderGame();
  showBanner(`TURN ${G.turnNum}`,'Your Move','var(--gr)');
}

function checkWin(){
  if(G.zHP<=0){
    STATS.wins++;STATS.totalGames++;
    G.locked=false;
    updateHomeStats();
    showEndScreen(true);
    return true;
  }
  if(G.pHP<=0){
    STATS.losses++;STATS.totalGames++;
    G.locked=false;
    updateHomeStats();
    showEndScreen(false);
    return true;
  }
  return false;
}

