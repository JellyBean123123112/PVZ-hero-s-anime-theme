    b.classList.toggle('on',tabIdx===i);
  });
  movePill(i);
  if(i===1)buildHeroList();
  if(i===2)buildDeckPool();
  if(i===5)renderHistory();
}
function movePill(tabIdx){
  // nav button order: Home(0) Heroes(1) Deck(2) Chests(3) History(5) Settings(4)
  const navOrder=[0,1,2,3,5,4];
  const navPos=navOrder.indexOf(tabIdx);
  if(navPos===-1)return;
  const nr=document.getElementById('nav').getBoundingClientRect();
  const br=NBS[navPos].getBoundingClientRect();
  PILL.style.left=(br.left-nr.left+5)+'px';
  PILL.style.width=(br.width-10)+'px';
}
