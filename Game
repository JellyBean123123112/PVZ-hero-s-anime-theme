/* ══════════════════════════════
   TRICK ACTIVATION
══════════════════════════════ */
function activateTrick(card){
  const idx=G.hand.findIndex(c=>c.uid===card.uid);
  if(idx===-1)return;
  if(G.sun<card.cost){notify('Need more ☀️','var(--ac)');return}
  const eff=card.effect||{};

  // tricks that need a target lane first
  if(eff.summon||eff.buffLane){
    openLaneSheetTrick(card);return;
  }

  // instant effects
  G.sun-=card.cost;
  G.hand.splice(idx,1);
  applyTrickEffect(eff,card,-1);
  renderGame();
}

function applyTrickEffect(eff,card,lane,caster='plant'){
  if(eff.dmgHero!==undefined){
    if(caster==='plant'){
      // player trick — damages zombie hero
      G.zHP=Math.max(0,G.zHP-eff.dmgHero);
      flashTrick(`⚡ -${eff.dmgHero} HP!`,'var(--ac)');
      document.getElementById('gzp').classList.add('a-shake');
      setTimeout(()=>document.getElementById('gzp').classList.remove('a-shake'),400);
    } else {
      // AI zombie trick — damages plant hero
      G.pHP=Math.max(0,G.pHP-eff.dmgHero);
      flashTrick(`💀 -${eff.dmgHero} HP!`,'var(--rd)');
      document.getElementById('gpp').classList.add('a-shake');
      setTimeout(()=>document.getElementById('gpp').classList.remove('a-shake'),400);
    }
  }
  if(eff.extraSun){G.sun=Math.min(G.sun+eff.extraSun,10);notify(`+${eff.extraSun} ☀️`,'var(--ac)')}
  if(eff.extraBrains){G.brains=Math.min(G.brains+eff.extraBrains,10);notify(`+${eff.extraBrains} Brains`,'var(--rd)')}
  if(eff.heal){G.pHP=Math.min(G.pHP+eff.heal,G.pHPmax);notify(`+${eff.heal} HP ❤️`,'var(--gr)')}
  if(eff.draw){
    const drawn=Math.min(eff.draw,HAND_LIMIT-G.hand.length,G.gameDeck.length);
    for(let i=0;i<drawn;i++)drawCard();
    if(drawn>0)notify(`Drew ${drawn} card${drawn>1?'s':''}! 🃏`,'var(--bl)');
    else notify('Hand full or deck empty','var(--mu)');
  }
  if(eff.buffAll){
    let buffed=0;
    G.pRow.forEach(c=>{if(c){if(eff.buffAll.atk)c.atk+=eff.buffAll.atk;if(eff.buffAll.hp){c.hp+=eff.buffAll.hp;c.curHP=(c.curHP||c.hp)+eff.buffAll.hp;}buffed++;}});
    if(buffed>0)flashTrick(`💪 All allies +${eff.buffAll.atk||0}/+${eff.buffAll.hp||0}!`,'var(--gr)');
    else notify('No allies on board','var(--mu)');
  }
  if(eff.dmgAllPlants){
    // AI only — damages all plants
    G.pRow.forEach((c,i)=>{
      if(c){
        c.curHP=(c.curHP||c.hp)-eff.dmgAllPlants;
        if(c.curHP<=0)G.pRow[i]=null;
      }
    });
    flashTrick(`☄️ -${eff.dmgAllPlants} to all plants!`,'var(--rd)');
  }
  if(eff.freezeAll){
    G.frozenZones=G.zRow.map((c,i)=>c?i:-1).filter(i=>i>=0);
    flashTrick('❄️ FROZEN!','var(--bl)');
  }
  if(eff.destroyWeakest){
    let minHP=Infinity,minLane=-1;
    G.pRow.forEach((c,i)=>{if(c&&(c.curHP||c.hp)<minHP){minHP=c.curHP||c.hp;minLane=i}});
    if(minLane>=0){G.pRow[minLane]=null;flashTrick('💀 Destroyed!','var(--rd)')}
    else notify('No plants to destroy','var(--mu)');
  }
  if(eff.spawnZombies){
    const free=G.zRow.map((v,i)=>v?-1:i).filter(i=>i>=0);
    for(let j=0;j<eff.spawnZombies&&free.length;j++){
      const pick=free.splice(Math.floor(Math.random()*free.length),1)[0];
      const demon=CARDS.find(c=>c.id==='z10')||CARDS.find(c=>c.type==='zombie');
      G.zRow[pick]=mkCard(demon);
    }
    flashTrick('🌹 Demons summoned!','var(--rd)');
  }
  if(eff.summon&&lane>=0){
    if(!G.pRow[lane]){
      G.pRow[lane]=mkCard(eff.summon);
      flashTrick('🍄 Summoned!','var(--gr)');
    } else notify('Lane occupied','var(--rd)');
  }
  if(eff.buffLane&&lane>=0&&G.pRow[lane]){
    G.pRow[lane].atk=(G.pRow[lane].atk||0)+eff.buffLane.atk;
    G.pRow[lane].curHP=(G.pRow[lane].curHP||G.pRow[lane].hp)+eff.buffLane.hp;
    G.pRow[lane].hp=(G.pRow[lane].hp||0)+eff.buffLane.hp;
    flashTrick(`⬆️ +${eff.buffLane.atk}/+${eff.buffLane.hp}`,'var(--gr)');
  }
}

function flashTrick(msg,color){
  const ov=document.createElement('div');
  ov.className='trick-overlay';ov.textContent=msg;ov.style.color=color;
  document.body.appendChild(ov);
  setTimeout(()=>ov.remove(),900);
}

